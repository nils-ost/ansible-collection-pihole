services:
  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    environment:
      TZ: '{{ pihole_timezone }}'
      FTLCONF_webserver_api_password: '{{ pihole_api_password }}'
      FTLCONF_dns_listeningMode: 'all'
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "{{ pihole_port }}:80/tcp"
    volumes:
      - './etc-pihole:/etc/pihole'
    cap_add:
      - SYS_NICE

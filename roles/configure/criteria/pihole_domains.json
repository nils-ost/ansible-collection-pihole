{
  "type": "object",
  "propertyNames": {
    "pattern": "^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9][a-z0-9-]{0,61}[a-z0-9]$",
    "description": "Needs to be an valid FQDN (DNS-Name)"
  },
  "patternProperties": {
    "^.*": {
      "type": "string",
      "enum": ["deny", "allow"]
    }
  }
}
